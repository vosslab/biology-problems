$sim_html .= "<span><span class='eleg-dot' style='background:$color_glucose;'></span> Glucose</span>";
$sim_html .= "<span><span class='eleg-dot' style='background:$color_amylase;'></span> Amylase (enzyme)</span>";
$sim_html .= "<span><span class='eleg-dot' style='background:$color_maltase;'></span> Maltase (enzyme)</span>";
$sim_html .= '</div>';

# canvases
$sim_html .= '<div class="enzyme-sim-canvases">';
$sim_html .= '<canvas id="esim_beaker" width="420" height="320">Reaction Beaker</canvas>';
$sim_html .= '<canvas id="esim_graph" width="420" height="320">Concentration Graph</canvas>';
$sim_html .= '</div>';

# sliders
$sim_html .= '<div class="enzyme-sim-controls">';

$sim_html .= '<div class="enzyme-slider-group">';
$sim_html .= "<label style='color:$color_starch;'>Starch:</label>";
$sim_html .= '<input type="range" id="esim_starch" class="eslider-starch" min="0" max="5" step="0.5" value="3">';
$sim_html .= '<span id="esim_val_starch" class="eslider-val">3.0</span> mM';
$sim_html .= '</div>';

$sim_html .= '<div class="enzyme-slider-group">';
$sim_html .= "<label style='color:$color_maltose;'>Maltose:</label>";
$sim_html .= '<input type="range" id="esim_maltose" class="eslider-maltose" min="0" max="5" step="0.5" value="0">';
$sim_html .= '<span id="esim_val_maltose" class="eslider-val">0.0</span> mM';
$sim_html .= '</div>';

$sim_html .= '<div class="enzyme-slider-group">';
$sim_html .= "<label style='color:$color_glucose;'>Glucose:</label>";
$sim_html .= '<input type="range" id="esim_glucose" class="eslider-glucose" min="0" max="5" step="0.5" value="0">';
$sim_html .= '<span id="esim_val_glucose" class="eslider-val">0.0</span> mM';
$sim_html .= '</div>';

$sim_html .= '<div class="enzyme-slider-group">';
$sim_html .= "<label style='color:$color_amylase;'>Amylase:</label>";
$sim_html .= '<input type="range" id="esim_amylase" class="eslider-amylase" min="0" max="5" step="0.5" value="2">';
$sim_html .= '<span id="esim_val_amylase" class="eslider-val">2.0</span> mM';
$sim_html .= '</div>';

$sim_html .= '<div class="enzyme-slider-group">';
$sim_html .= "<label style='color:$color_maltase;'>Maltase:</label>";
$sim_html .= '<input type="range" id="esim_maltase" class="eslider-maltase" min="0" max="5" step="0.5" value="2">';
$sim_html .= '<span id="esim_val_maltase" class="eslider-val">2.0</span> mM';
$sim_html .= '</div>';

$sim_html .= '</div>';

# buttons
$sim_html .= '<div class="enzyme-sim-buttons">';
$sim_html .= '<button id="esim_run" type="button">Run</button>';
$sim_html .= '<button id="esim_pause" type="button">Pause</button>';
$sim_html .= '<button id="esim_reset" type="button">Reset</button>';
$sim_html .= '</div>';
$sim_html .= '</div>';

# ----------------------------
# 2f) Colored reaction descriptions
# ----------------------------
$rxn1_desc = "<span style='color:$color_amylase; font-weight:bold;'>Amylase</span>"
	. " breaks down <span style='color:$color_starch; font-weight:bold;'>starch</span>"
	. " into <span style='color:$color_maltose; font-weight:bold;'>maltose</span>";
$rxn1_formula = "<span style='color:$color_starch;'>Starch</span>"
	. " + <span style='color:$color_amylase;'>Amylase</span>"
	. " &rarr; 2 <span style='color:$color_maltose;'>Maltose</span>";

$rxn2_desc = "<span style='color:$color_maltase; font-weight:bold;'>Maltase</span>"
	. " breaks down <span style='color:$color_maltose; font-weight:bold;'>maltose</span>"
	. " into <span style='color:$color_glucose; font-weight:bold;'>glucose</span>";
$rxn2_formula = "<span style='color:$color_maltose;'>Maltose</span>"
	. " + <span style='color:$color_maltase;'>Maltase</span>"
	. " &rarr; 2 <span style='color:$color_glucose;'>Glucose</span>";

# ----------------------------
# 3) Statement (PGML)
# ----------------------------
BEGIN_PGML

This simulation models a two-step enzymatic pathway:

- [$rxn1_desc]*
[$rxn1_formula]*

- [$rxn2_desc]*
[$rxn2_formula]*

Enzymes are shown as circles with a small notch (representing the active site). Substrates and products are shown as filled circles of varying size.

Use the sliders to set starting concentrations (0-5 mM), then click *Run* to start the simulation. Observe how concentrations change over time in the graph.

[$sim_html]*

---

*Answer the following questions about enzyme mechanisms based on what you observe.*

*Question 1.* [$q1_text]*

[_]{$rb1}

*Question 2.* [$q2_text]*

[_]{$rb2}

*Question 3.* [$q3_text]*

[_]{$rb3}

END_PGML

# ----------------------------
# 4) Solution
# ----------------------------
BEGIN_PGML_SOLUTION
*Explanations:*

*Q1.* [$q1_explain]*

*Q2.* [$q2_explain]*

*Q3.* [$q3_explain]*

*Key concepts:*

- Enzymes are catalysts: they speed up reactions without being consumed.
- Reaction rate depends on both enzyme and substrate concentration.
- The final amount of product depends on the starting substrate, not the enzyme amount.
- Sequential pathways create delays: maltose must be produced before maltase can generate glucose.
END_PGML_SOLUTION

ENDDOCUMENT();
