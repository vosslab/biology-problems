    '<span style="color: #076dad; font-weight:700;">Uncompetitive&nbsp;inhibitors</span> <span style="color: #a719db; font-weight:700;">bind</span>to the <span style="color: #c80085; font-weight:700;">active site</span> of an enzyme and compete with the<span style="color: #b74300; font-weight:700;">substrate</span> for <span style="color: #a719db; font-weight:700;">binding</span>.',
    '<span style="color: #076dad; font-weight:700;">Uncompetitive&nbsp;inhibitors</span> <span style="color: #a719db; font-weight:700;">bind</span>to the <span style="color: #c80085; font-weight:700;">active site</span> of an enzyme.',
    '<span style="color: #076dad; font-weight:700;">Uncompetitive&nbsp;inhibitors</span> compete with the<span style="color: #b74300; font-weight:700;">substrate</span> for <span style="color: #c80085; font-weight:700;">active site</span> <span style="color: #a719db; font-weight:700;">binding</span>.',
    '<span style="color: #076dad; font-weight:700;">Uncompetitive&nbsp;inhibitors</span> <span style="color: #a719db; font-weight:700;">bind</span>to the enzyme and prevent<span style="color: #b74300; font-weight:700;">substrate</span> <span style="color: #a719db; font-weight:700;">binding</span>.',
    '<span style="color: #d40000; font-weight:700;">Competitive&nbsp;inhibitors</span> do NOT compete with the<span style="color: #b74300; font-weight:700;">substrate</span> for <span style="color: #c80085; font-weight:700;">active site</span> <span style="color: #a719db; font-weight:700;">binding</span>.',
    '<span style="color: #d40000; font-weight:700;">Competitive&nbsp;inhibitors</span> do NOT <span style="color: #a719db; font-weight:700;">bind</span>to the <span style="color: #c80085; font-weight:700;">active site</span> of an enzyme.',
    '<span style="color: #d40000; font-weight:700;">Competitive&nbsp;inhibitors</span> do NOT <span style="color: #a719db; font-weight:700;">bind</span>to the enzyme to prevent<span style="color: #b74300; font-weight:700;">substrate</span> <span style="color: #a719db; font-weight:700;">binding</span>.',
