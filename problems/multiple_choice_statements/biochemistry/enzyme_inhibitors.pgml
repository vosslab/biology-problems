## TITLE('Biochemistry: Enzyme Inhibitor Types and Kinetic Effects')
## DESCRIPTION
## Evaluate true or false statements about competitive, non-competitive, uncompetitive, and mixed enzyme inhibitors and their effects on kinetic parameters.
## ENDDESCRIPTION
## KEYWORDS('enzyme inhibitors','competitive inhibition','non-competitive inhibition','multiple choice')
## DBsubject('Biochemistry')
## DBchapter('')
## DBsection('')
## Date('2026-03-14')
## Author('Neil R. Voss')
## Institution('Roosevelt University')

DOCUMENT();

loadMacros(
  "PGstandard.pl",
  "PGML.pl",
  "PGchoicemacros.pl",
  "parserRadioButtons.pl",
  "PGcourse.pl",
);

TEXT(beginproblem());
$showPartialCorrectAnswers = 1;

#==========================================================
# AUTO-GENERATED GROUPS FROM YAML
#==========================================================

@true_groups = (
