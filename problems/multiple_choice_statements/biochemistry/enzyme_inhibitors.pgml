    '<span style="color: #d40000; font-weight:700;">Competitive&nbsp;inhibitors</span> compete with the<span style="color: #b74300; font-weight:700;">substrate</span> for <span style="color: #c80085; font-weight:700;">active site</span> <span style="color: #a719db; font-weight:700;">binding</span>.',
